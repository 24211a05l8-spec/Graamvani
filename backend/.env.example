PORT=5000

# Firebase Configuration
# Path to your service account key JSON file (e.g. ./firebase-key.json)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-key.json

# Twilio Credentials (Optional for Demo)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Text-to-Speech (Can use Google Cloud TTS or others)
GOOGLE_APPLICATION_CREDENTIALS=./google-auth.json
